{
  "name": "@somarc/da-cli-0-6-0-site",
  "private": true,
  "version": "1.3.0",
  "description": "Release certification and dogfood site for @somarc/da-cli 0.6.0",
  "scripts": {
    "lint:js": "eslint .",
    "lint:css": "stylelint \"blocks/**/*.css\" \"styles/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix",
    "check:da-source-truth": "node scripts/check-da-source-truth.mjs",
    "check:provenance": "node scripts/verify-provenance.mjs",
    "write:provenance": "node scripts/verify-provenance.mjs --write",
    "audit:provenance": "node scripts/verify-provenance.mjs --live",
    "audit:provenance:strict": "node scripts/verify-provenance.mjs --live --strict-freeze",
    "audit:release": "node scripts/release-audit.mjs",
    "audit:dependencies": "npm audit --audit-level=high",
    "worker:form-submit": "npx wrangler dev --config ./workers/form-submit/wrangler.toml",
    "worker:auth-session": "npx wrangler dev --config ./workers/auth-session/wrangler.toml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somarc/da-cli-0-6-0.git"
  },
  "author": "Somarc",
  "license": "Apache License 2.0",
  "bugs": {
    "url": "https://github.com/somarc/da-cli-0-6-0/issues"
  },
  "homepage": "https://main--da-cli-0-6-0--somarc.aem.live/",
  "devDependencies": {
    "@babel/eslint-parser": "7.29.7",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.32.0",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0"
  }
}
